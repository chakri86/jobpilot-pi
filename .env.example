# App
APP_NAME=JobPilot Pi
ENVIRONMENT=production
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALLOWED_ORIGINS=http://192.168.0.249:5000,http://localhost:5000,http://localhost:5173

# First-run admin. Do not commit real passwords.
BOOTSTRAP_ADMIN_EMAIL=avkc@jobpilot.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-the-pi
BOOTSTRAP_ADMIN_FORCE_PASSWORD_CHANGE=true

# Database
POSTGRES_USER=jobpilot
POSTGRES_PASSWORD=jobpilot-change-me
POSTGRES_DB=jobpilot
DATABASE_URL=postgresql+psycopg://jobpilot:jobpilot-change-me@db:5432/jobpilot

# AI
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# Runtime
DEFAULT_SCAN_INTERVAL_MINUTES=5
MAX_UPLOAD_MB=5
UPLOAD_DIR=/app/backend/uploads
LOG_LEVEL=INFO
